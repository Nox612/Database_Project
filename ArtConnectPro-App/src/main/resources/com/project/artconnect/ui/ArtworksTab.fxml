<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="artistColumn" text="Artist" prefWidth="150" />
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100" />
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="100" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="150" />
        </columns>
    </TableView>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="titleInput" promptText="Title" />
        <TextField fx:id="typeInput" promptText="Type" prefWidth="100" />
        <TextField fx:id="priceInput" promptText="Price" prefWidth="80" />
        <ComboBox fx:id="statusInput" promptText="Status" prefWidth="100" />
        <TextField fx:id="artistInput" promptText="Artist Name" />
        <Button text="Add" onAction="#handleAdd" />
        <Button text="Update" onAction="#handleUpdate" />
        <Button text="Delete" onAction="#handleDelete" />
    </HBox>
</VBox>
